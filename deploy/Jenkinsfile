pipeline {
    agent any

    environment {
        DEPLOY_DIR    = '/opt/studymate/deploy'
        BACKEND_REPO  = 'https://github.com/impku-ibm/studymate-service.git'
        FRONTEND_REPO = 'https://github.com/impku-ibm/studymate-ui.git'
    }

    stages {
        stage('Checkout Backend') {
            steps {
                dir('backend') {
                    git branch: 'main', url: "${BACKEND_REPO}"
                }
            }
        }

        stage('Checkout Frontend') {
            steps {
                dir('frontend') {
                    git branch: 'main', url: "${FRONTEND_REPO}"
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh '''
                        export VITE_API_URL=""
                        npm ci --prefer-offline
                        npm run build
                    '''
                }
            }
        }

        stage('Test Backend') {
            steps {
                dir('backend') {
                    sh './gradlew test --no-daemon || true'
                }
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    # Copy frontend build
                    rm -rf ${DEPLOY_DIR}/frontend/dist
                    cp -r frontend/dist ${DEPLOY_DIR}/frontend/dist

                    # Copy backend source (Docker builds it)
                    rsync -a --delete backend/ ${DEPLOY_DIR}/backend/ \
                        --exclude='.git' --exclude='build' --exclude='.gradle'

                    # Rebuild and restart
                    cd ${DEPLOY_DIR}
                    docker compose -f docker-compose.prod.yml build backend
                    docker compose -f docker-compose.prod.yml up -d
                    docker compose -f docker-compose.prod.yml restart nginx
                """
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    sleep 30
                    curl -sf http://localhost/actuator/health || echo "Health check pending..."
                '''
            }
        }
    }

    post {
        failure {
            echo 'Deployment failed. Check logs with: docker compose logs backend'
        }
        success {
            echo 'Deployment successful.'
        }
    }
}
